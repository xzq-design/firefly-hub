{
    "project": "Lumi-Hub",
    "version": "0.1.0",
    "description": "替代 QQ 的自建消息前端，对接 AstrBot + OpenClaw + MCP",
    "architecture": {
        "type": "Monorepo",
        "directories": {
            "host": {
                "description": "AstrBot 自定义平台适配器 (Python)",
                "sub_dirs": [
                    "core",
                    "auth",
                    "personas",
                    "config"
                ],
                "note": "通过符号链接接入 AstrBot/data/plugins/"
            },
            "agent": {
                "description": "执行引擎，OpenClaw + MCP 工具",
                "sub_dirs": [
                    "executor",
                    "mcp_tools",
                    "cache_mgr"
                ]
            },
            "client": {
                "description": "自建聊天前端，Flutter 跨平台 (Android/iOS/Windows)",
                "sub_dirs": [
                    "lib/core",
                    "lib/ui",
                    "lib/models"
                ]
            },
            ".lumi_cache": {
                "description": "安全备份缓存区 (由 Agent 管理)",
                "sub_dirs": [
                    "backups",
                    "logs"
                ]
            }
        }
    },
    "websocket_protocol": {
        "envelope_structure": {
            "message_id": "string (UUID，用于请求/响应匹配)",
            "type": "string (消息类型枚举)",
            "source": "enum: client | host | agent",
            "target": "enum: client | host | agent",
            "timestamp": "integer (UNIX 毫秒时间戳)",
            "payload": "object (根据 type 变化)"
        },
        "message_types": {
            "connection": {
                "types": [
                    "PING",
                    "PONG",
                    "CONNECT",
                    "DISCONNECT"
                ],
                "description": "连接管理与心跳保活"
            },
            "chat": {
                "types": [
                    "CHAT_REQUEST",
                    "CHAT_RESPONSE",
                    "CHAT_STREAM_CHUNK"
                ],
                "description": "基础对话流，Client ↔ Host ↔ AstrBot"
            },
            "security": {
                "types": [
                    "AUTH_REQUIRED",
                    "AUTH_RESPONSE",
                    "AUTH_TIMEOUT"
                ],
                "description": "高危操作拦截审批 (Human-in-the-loop)"
            },
            "task": {
                "types": [
                    "TASK_EXECUTE",
                    "TASK_STATUS_UPDATE",
                    "TASK_COMPLETE",
                    "UNDO_REQUEST",
                    "UNDO_RESPONSE"
                ],
                "description": "任务执行与状态追踪"
            },
            "persona": {
                "types": [
                    "PERSONA_SWITCH",
                    "PERSONA_LIST",
                    "PERSONA_INFO"
                ],
                "description": "人格包管理（切换/查询/详情）"
            },
            "system": {
                "types": [
                    "SYSTEM_NOTIFICATION",
                    "ERROR_ALERT",
                    "CACHE_CLEANUP"
                ],
                "description": "系统通知与缓存管理"
            }
        },
        "enums": {
            "action_type": [
                "FILE_READ",
                "FILE_MODIFY",
                "FILE_DELETE",
                "FILE_CREATE",
                "GIT_COMMIT",
                "GIT_PUSH",
                "COMMAND_EXEC",
                "NOTION_WRITE"
            ],
            "risk_level": [
                "LOW",
                "MEDIUM",
                "HIGH"
            ],
            "task_status": [
                "PENDING",
                "WAITING_APPROVAL",
                "BACKUP_CREATING",
                "EXECUTING",
                "SUCCESS",
                "FAILED",
                "CANCELLED",
                "UNDONE"
            ],
            "auth_decision": [
                "APPROVED",
                "REJECTED",
                "TIMEOUT",
                "QUEUED"
            ]
        },
        "examples": {
            "CHAT_REQUEST": {
                "message_id": "msg-001",
                "type": "CHAT_REQUEST",
                "source": "client",
                "target": "host",
                "timestamp": 1700000000000,
                "payload": {
                    "content": "帮我看看项目目录下有什么文件",
                    "context_id": "session-abc"
                }
            },
            "CHAT_RESPONSE": {
                "message_id": "msg-001",
                "type": "CHAT_RESPONSE",
                "source": "host",
                "target": "client",
                "timestamp": 1700000005000,
                "payload": {
                    "content": "目录下目前有 readme.md 和 protocol.json 两个文件。",
                    "status": "success",
                    "persona": "lumi"
                }
            },
            "AUTH_REQUIRED": {
                "message_id": "msg-002",
                "type": "AUTH_REQUIRED",
                "source": "host",
                "target": "client",
                "timestamp": 1700000100000,
                "payload": {
                    "task_id": "task-789",
                    "action_type": "FILE_MODIFY",
                    "risk_level": "HIGH",
                    "target_path": "e:\\Lumi-Hub\\readme.md",
                    "description": "准备修改 readme.md，添加法律声明章节",
                    "diff_preview": "@@ -150,3 +150,20 @@\n+ ## 法律声明\n+ ...",
                    "tool_name": "write_file",
                    "timeout_seconds": 30
                }
            },
            "AUTH_RESPONSE": {
                "message_id": "msg-002-reply",
                "type": "AUTH_RESPONSE",
                "source": "client",
                "target": "host",
                "timestamp": 1700000115000,
                "payload": {
                    "task_id": "task-789",
                    "decision": "APPROVED",
                    "reason": ""
                }
            },
            "TASK_STATUS_UPDATE": {
                "message_id": "msg-003",
                "type": "TASK_STATUS_UPDATE",
                "source": "host",
                "target": "client",
                "timestamp": 1700000120000,
                "payload": {
                    "task_id": "task-789",
                    "status": "BACKUP_CREATING",
                    "message": "正在创建安全备份..."
                }
            },
            "PERSONA_SWITCH": {
                "message_id": "msg-004",
                "type": "PERSONA_SWITCH",
                "source": "client",
                "target": "host",
                "timestamp": 1700000200000,
                "payload": {
                    "persona_id": "lumi",
                    "persona_name": "流萤"
                }
            },
            "UNDO_REQUEST": {
                "message_id": "msg-005",
                "type": "UNDO_REQUEST",
                "source": "client",
                "target": "host",
                "timestamp": 1700000300000,
                "payload": {
                    "task_id": "task-789"
                }
            },
            "SYSTEM_NOTIFICATION": {
                "message_id": "msg-006",
                "type": "SYSTEM_NOTIFICATION",
                "source": "host",
                "target": "client",
                "timestamp": 1700000400000,
                "payload": {
                    "notification_type": "CACHE_CLEANUP",
                    "content": "本地缓存已超过 5GB，建议清理。",
                    "actions": [
                        "一键清理",
                        "暂不处理"
                    ]
                }
            }
        }
    }
}